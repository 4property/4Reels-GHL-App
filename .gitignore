# ── Dependencies ────────────────────────────────────────────────────
node_modules

# ── Build output ────────────────────────────────────────────────────
dist
dist-ssr
build
out

# ── Vite ────────────────────────────────────────────────────────────
.vite
.vite-inspect

# ── Logs ────────────────────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ── Environment / secrets ───────────────────────────────────────────
# Keep .env.example committed (template); never commit real values.
.env
.env.local
.env.*.local
*.pem
*.key

# ── Local overrides (Vite picks these up automatically) ─────────────
*.local

# ── Caches ──────────────────────────────────────────────────────────
.cache
.parcel-cache
.eslintcache
.stylelintcache
.npm

# ── Test / coverage ─────────────────────────────────────────────────
coverage
*.lcov
.nyc_output

# ── Playwright ──────────────────────────────────────────────────────
# Ignore per-run output. Visual baselines live next to each spec in a
# `*-snapshots/` folder and MUST be committed — the negation below makes
# that intent explicit so a stray rule can't silently drop them.
test-results
playwright-report
blob-report
playwright/.cache
!tests/**/*-snapshots/
!tests/**/*-snapshots/**

# ── TypeScript (kept for when we add types) ─────────────────────────
*.tsbuildinfo

# ── Editors / IDEs ──────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea
.history
*.suo
*.sw?

# ── Scratch / temp ──────────────────────────────────────────────────
tmp
.tmp
*.bak
*.orig
*.tgz

# ── OS junk ─────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
