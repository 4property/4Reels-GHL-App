dist
dist-ssr
build
out

# ── Vite ────────────────────────────────────────────────────────────
.vite
.vite-inspect

# ── Logs ────────────────────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Environment / secrets ───────────────────────────────────────────
