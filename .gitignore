.env
.env.local
.env.*.local
*.pem
*.key

# ── Local overrides ─────────────────────────────────────────────────
*.local

# ── Caches ──────────────────────────────────────────────────────────
.cache
.parcel-cache
.eslintcache
.stylelintcache
.npm
.yarn/*
!.yarn/patches
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions

# ── Test / coverage ─────────────────────────────────────────────────
coverage
*.lcov
.nyc_output

# ── Playwright (added with the capture script) ──────────────────────
test-results
playwright-report
blob-report
playwright/.cache
scripts/screenshots

# ── TypeScript (kept for when we add types) ─────────────────────────
*.tsbuildinfo

# ── Editors / IDEs ──────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

